# ── Base de données (Neon PostgreSQL) ────────────────────────────────────────
# Récupérez cette URL depuis votre dashboard Neon (https://console.neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/mats?sslmode=require

# ── Authentification ──────────────────────────────────────────────────────────
# Générez une chaîne aléatoire de 32+ caractères : openssl rand -base64 32
JWT_SECRET=your_secure_random_secret_min_32_chars

# Clé à usage unique pour créer le premier compte admin via /trpc/auth.createAdminAccount
SETUP_KEY=choose_a_strong_one_time_setup_key

# ── SMS (Twilio) — optionnel ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Email (Nodemailer) — optionnel ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Environnement ──────────────────────────────────────────────────────────────
NODE_ENV=production
